{
  "manifest_version": 3,
  "name": "Volume Booster for Firefox",
  "version": "1.0",
  "description": "Control the audio volume of each tab individually.",
  "permissions": ["storage", "tabs"],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "96": "assets/icon-96.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"]
    }
  ],
"browser_specific_settings": {
    "gecko": {
      "id": "volumebooster-extension@lololol.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}